# Copy to .env and fill in real values:
#   cp .env.example .env
# .env is gitignored.

# --- Postgres (docker-compose substitution) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=genshin_banpick

# --- Backend ---
# DATABASE_URL: 給 host dev (`npm run dev`) 用，連 host 的 Postgres
# Docker 跑時 docker-compose.yml 會用 POSTGRES_* 自己組一條覆蓋掉
DATABASE_URL=postgresql://USER@localhost:5432/genshin_banpick
JWT_SECRET=run-`node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173

# --- Frontend (VITE_* 前綴才會打包進 client bundle) ---
VITE_API_URL=/api
VITE_SOCKET_URL=
VITE_LOG_LEVEL=info
